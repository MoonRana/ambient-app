{
  "expo": {
    "name": "DoMyNote Ambient",
    "slug": "domynote-ambient",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#051336"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.domynote.ambient",
      "infoPlist": {
        "UIBackgroundModes": ["audio", "fetch", "remote-notification"],
        "NSMicrophoneUsageDescription": "DoMyNote needs microphone access to record patient encounters for clinical note generation.",
        "NSCameraUsageDescription": "DoMyNote needs camera access to photograph insurance cards, lab results, and prescriptions.",
        "NSPhotoLibraryUsageDescription": "DoMyNote needs photo library access to select existing photos of medical documents.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.domynote.ambient",
      "adaptiveIcon": {
        "backgroundColor": "#051336",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "DoMyNote needs photo library access to select medical documents.",
          "cameraPermission": "DoMyNote needs camera access to photograph medical documents."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "DoMyNote needs microphone access to record encounters."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "61103b32-59ec-4c5d-841d-1cd528f8c606"
      }
    },
    "owner": "moonrana",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/61103b32-59ec-4c5d-841d-1cd528f8c606"
    }
  }
}
